{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Start Menu",
            "type": "shell",
            "command": "C:\\MinGW\\bin\\g++.exe",
            "args": [
                "-g",

                "${workspaceFolder}\\src\\main.cpp",
                "${workspaceFolder}\\src\\desktop.cpp",
                "${workspaceFolder}\\src\\taskbar.cpp",
                "${workspaceFolder}\\src\\startmenu.cpp",
                "${workspaceFolder}\\src\\mouse.cpp",
                "${workspaceFolder}\\src\\utils.cpp",

                "-I",
                "${workspaceFolder}\\include",

                "-o",
                "${workspaceFolder}\\bin\\app.exe",

                "-lbgi",
                "-lgdi32",
                "-lcomdlg32",
                "-luuid",
                "-loleaut32",
                "-lole32"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}