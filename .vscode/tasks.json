{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Start Menu",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "C:\\MinGW\\bin\\g++.exe -g src\\*.cpp -I include -o bin\\app.exe -lbgi -lgdi32 -lcomdlg32 -luuid -loleaut32 -lole32"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}